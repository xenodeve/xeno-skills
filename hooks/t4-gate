#!/usr/bin/env bash
# T4 PreToolUse gate — the one hard-enforcement layer. It only ever BLOCKS a
# tool call (deny); silence means "no opinion, let the normal flow proceed".
# Scoped to T4 repos via the `.claude/t4.json` marker.
#
# Rules:
#   - dangerous git is blocked     (reset --hard, force-push, clean -f, branch -D)
#   - PR needs a referenced issue  (PRD -> issues -> PR gate)
#   - ship gate: a green `verify` (.claude/t4.json) is required to MERGE a PR
#   - before-merge: `gh pr merge` asks to confirm review ran — skipped when
#     .claude/t4.json sets "autoMerge"/"afk": true (AFK / standing authorization)
set -uo pipefail

input="$(cat)"
[ -f ".claude/t4.json" ] || exit 0

# hooks.json already scopes this to the Bash tool; this in-process check is a
# cheap defensive guard for the bootstrap path, no subprocess.
tool=""
[[ "$input" =~ \"tool_name\"[[:space:]]*:[[:space:]]*\"([^\"]*)\" ]] && tool="${BASH_REMATCH[1]}"
[ "$tool" = "Bash" ] || exit 0

cmd="$(printf '%s' "$input" | perl -0777 -ne '
  if (/"command"\s*:\s*"((?:\\.|[^"\\])*)"/s) {
    my $c=$1; $c=~s/\\n/\n/g; $c=~s/\\t/\t/g; $c=~s/\\"/"/g; $c=~s/\\\\/\\/g; print $c;
  }')"

_decide() {  # $1 = deny|ask ; $2 = reason
  local r="$2"
  r="${r//\\/\\\\}"; r="${r//\"/\\\"}"; r="${r//$'\n'/\\n}"; r="${r//$'\r'/\\r}"; r="${r//$'\t'/\\t}"
  printf '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"%s","permissionDecisionReason":"%s"}}\n' "$1" "$r"
  exit 0
}
deny() { _decide deny "$1"; }
ask()  { _decide ask  "$1"; }

# Runs the repo's configured verify command (.claude/t4.json "verify") itself, so
# the ship gate is real, un-forgeable enforcement — not a claim to trust.
# Returns 0 when it passes OR when nothing is configured; 1 when it fails.
run_verify() {
  local vcmd
  vcmd="$(perl -0777 -ne 'print $1 if /"verify"\s*:\s*"((?:\\.|[^"\\])*)"/' < .claude/t4.json 2>/dev/null)"
  vcmd="${vcmd//\\\"/\"}"; vcmd="${vcmd//\\\\/\\}"
  [ -n "$vcmd" ] || return 0
  if command -v timeout >/dev/null 2>&1; then
    timeout 600 bash -c "$vcmd" >/dev/null 2>&1
  else
    bash -c "$vcmd" >/dev/null 2>&1
  fi
}

# --- dangerous git -----------------------------------------------------------
# Match against the command with quoted spans removed, so a dangerous pattern
# merely *mentioned* in a commit message / PR body / echo string ("fix: reset
# --hard was risky") doesn't trigger a false deny — a real destructive flag is an
# unquoted command arg. (An unquoted mention inside a non-git command is a rare,
# accepted edge.)
scan="$(printf '%s' "$cmd" | sed 's/"[^"]*"//g' | sed "s/'[^']*'//g")"
if [[ "$scan" =~ (^|[/\\\"[:space:]])git(\.exe)?([[:space:]]|$) ]]; then
  if [[ "$scan" =~ reset[[:space:]].*--hard ]]; then
    deny "T4 gate: 'git reset --hard' is destructive (discards working-tree changes). Park it, or run it yourself if you truly intend it."
  fi
  if [[ "$scan" =~ push ]] && [[ ! "$scan" =~ --force-with-lease ]] \
     && { [[ "$scan" =~ --force([^-]|$) ]] || [[ "$scan" =~ [[:space:]]-f([[:space:]]|$) ]]; }; then
    deny "T4 gate: force-push is blocked. Use --force-with-lease, or run it yourself if intended."
  fi
  if [[ "$scan" =~ clean[[:space:]] ]] && { [[ "$scan" =~ -[a-zA-Z]*f ]] || [[ "$scan" =~ --force ]]; }; then
    deny "T4 gate: 'git clean -f' deletes untracked files irreversibly. Park it, or run it yourself."
  fi
  if [[ "$scan" =~ branch[[:space:]].*-D ]]; then
    deny "T4 gate: 'git branch -D' force-deletes a branch (unmerged work lost). Use -d, or run it yourself."
  fi
fi

# --- PR needs a referenced issue --------------------------------------------
# Detect the command on the quote-stripped `scan` (so a commit message that just
# says "gh pr create" doesn't trip it); detect the issue ref on the raw `cmd`
# (so a ref inside a quoted --body still counts).
if [[ "$scan" =~ (^|[/\\\"[:space:]])gh(\.exe)? ]] && [[ "$scan" =~ pr[[:space:]]+create ]]; then
  ref=""
  [[ "$cmd" =~ \#[0-9]+ ]] && ref="yes"
  if [ -z "$ref" ] && [[ "$cmd" =~ --body-file[[:space:]=]+([^[:space:]]+) ]]; then
    bf="${BASH_REMATCH[1]}"
    [ -f "$bf" ] && grep -Eq '#[0-9]+' "$bf" && ref="yes"
  fi
  [ -n "$ref" ] || deny "T4 gate: a PR needs a referenced issue (PRD -> issues -> PR). Add an issue number (e.g. 'Closes #12') to the PR body/title, or file an issue first."
fi

# --- ship gate: MERGE is the ship point (verify + review) -------------------
# verify runs on `merge` only, not the iterative `create` (CI builds on push).
# Keep .claude/t4.json "verify" a FAST suite (unit + build + lint) and leave
# e2e to the CI required-check.
if [[ "$scan" =~ (^|[/\\\"[:space:]])gh(\.exe)? ]] && [[ "$scan" =~ pr[[:space:]]+merge ]]; then
  run_verify || deny "T4 gate: verify failed — the configured verify command (.claude/t4.json \"verify\") did not pass. A green verify is the ship gate; fix it before merging."
  # Standing authorization (AFK / auto-merge) skips the review-confirm ask — the
  # developer already authorized the batch, and re-asking a decided call is the
  # 'sticking' anti-pattern. The checkable guard (verify, above) still holds.
  if grep -Eq '"(autoMerge|afk)"[[:space:]]*:[[:space:]]*true' .claude/t4.json 2>/dev/null; then
    exit 0
  fi
  ask "T4 before-merge gate: confirm /scrutinize + /code-review (and /security-review if a boundary was touched) have run against the final change. Proceed with the merge?"
fi

exit 0
